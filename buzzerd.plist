<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key><string>buzzerd</string>
  <key>ProgramArguments</key>
  <array>
    <string>/PATH/TO/buzzerd</string>
    <string>/PATH/TO/buzzerd.json</string>
  </array>
  <key>RunAtLoad</key><true/>
  <key>KeepAlive</key><true/>
  <key>StandardOutPath</key><string>/tmp/buzzerd.log</string>
  <key>StandardErrorPath</key><string>/tmp/buzzerd.log</string>
</dict>
</plist>
